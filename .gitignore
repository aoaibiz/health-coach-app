# Monorepo root .gitignore. Each subproject (app/, api/) also has its own.

# dependencies
node_modules/

# next.js
.next/
/out/

# build output
dist/

# typescript
*.tsbuildinfo
next-env.d.ts

# wrangler local state (local D1 DB, caches)
.wrangler/

# secrets / local env — NEVER commit
.env
.env.*
.dev.vars
.dev.vars.*
# ...but DO commit the placeholder templates (no real values):
!.env.example
!.dev.vars.example

# internal runtime artifact — NEVER publish
outbox.jsonl

# misc
.DS_Store
*.log
npm-debug.log*
