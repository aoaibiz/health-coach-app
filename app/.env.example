# Example environment for the app/ frontend + Node server.
#
# Copy to `.env` (gitignored) for local dev, or set these as real environment
# variables in your deployment. NEXT_PUBLIC_* values are baked into the static
# build at build time; the rest are read by the Node server (server/index.mjs)
# at runtime.

# --- Node server (runtime) --------------------------------------------------

# Shared secret required for the /api/analyze-meal and /api/chat routes. The
# client must send it as the `x-health-app-token` header. If unset, those routes
# fail closed (503). Use a long random value. NEVER commit the real token.
HEALTH_APP_TOKEN=replace-with-a-long-random-secret

# Path to the Codex CLI binary used for meal analysis + chat (subscription path,
# no API key). Defaults to `codex` on PATH if unset.
CODEX_BIN=codex

# Max concurrent Codex calls (analyze-meal + chat share this semaphore).
# Positive integer; defaults to 2.
HEALTH_APP_MAX_CONCURRENCY=2

# Port the Node server listens on. Defaults to 8787.
PORT=8787

# --- Frontend (build-time, NEXT_PUBLIC_*) -----------------------------------

# Base URL of the api/ Worker (auth + per-user data + push). The app calls it
# cross-origin with credentials. REQUIRED for a real deploy — set it to your own
# API origin (the code default is a neutral placeholder).
NEXT_PUBLIC_HEALTH_API=https://<your-api-host>

# --- Optional / legacy ------------------------------------------------------

# ANTHROPIC_API_KEY is ONLY used by the optional legacy meal-vision provider
# (functions/_llm/anthropic.ts). The default runtime path is the subscription
# Codex CLI and needs NO API key, so leave this unset unless you deliberately
# wire up the Anthropic provider.
# ANTHROPIC_API_KEY=
