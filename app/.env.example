# Example environment for the app/ frontend + Node server.
#
# Copy to `.env` (gitignored) for local dev, or set these as real environment
# variables in your deployment. NEXT_PUBLIC_* values are baked into the static
# build at build time; the rest are read by the Node server (server/index.mjs)
# at runtime.

# --- Node server (runtime) --------------------------------------------------

# Shared secret required for the /api/analyze-meal and /api/chat routes. The
# client must send it as the `x-health-app-token` header. If unset, those routes
# fail closed (503). Use a long random value. NEVER commit the real token.
# (Node server reads HEALTH_APP_TOKEN; a Cloudflare Pages self-host deploy uses
#  APP_ACCESS_TOKEN below for the SAME header — they are the same gate.)
HEALTH_APP_TOKEN=replace-with-a-long-random-secret

# --- AI mode (which backend powers meal analysis + chat) --------------------
# AI_MODE selects the AI backend. ONE place decides it (functions/_llm/select.ts):
#   local-codex  (default / unset) → subscription Codex CLI, NO API key. This is
#                 what our/family instances use.
#   own          → bring YOUR OWN AI key (for a member self-host deploy). Pair it
#                 with AI_PROVIDER + that provider's key below.
AI_MODE=local-codex

# Own-key provider, used only when AI_MODE=own. Currently supported: gemini.
# AI_PROVIDER=gemini

# Your OWN Google Gemini API key (only when AI_MODE=own + AI_PROVIDER=gemini).
# Get a FREE key from Google AI Studio (https://aistudio.google.com/apikey).
# Read from runtime env ONLY — never logged, never committed.
# GEMINI_API_KEY=

# Models for the own-key (Gemini) path; both default to a free-tier Flash model
# (gemini-2.0-flash) and are overridable. Check the current free-tier model id on
# Google AI Studio and override here if Google has renamed it.
# MEAL_VISION_MODEL=gemini-2.0-flash
# CHAT_MODEL=gemini-2.0-flash

# Access token for a Cloudflare Pages self-host deploy's /api routes (the CF
# Pages Functions check X-Health-App-Token against this). Same role as
# HEALTH_APP_TOKEN on the Node server. If unset, the CF routes fail closed (503).
# APP_ACCESS_TOKEN=replace-with-a-long-random-secret

# Path to the Codex CLI binary used for meal analysis + chat on the local-codex
# path (subscription, no API key). Defaults to `codex` on PATH if unset.
CODEX_BIN=codex

# Max concurrent Codex calls (analyze-meal + chat share this semaphore).
# Positive integer; defaults to 2.
HEALTH_APP_MAX_CONCURRENCY=2

# Port the Node server listens on. Defaults to 8787.
PORT=8787

# --- Frontend (build-time, NEXT_PUBLIC_*) -----------------------------------

# Base URL of the api/ Worker (auth + per-user data + push). The app calls it
# cross-origin with credentials. REQUIRED for a real deploy — set it to your own
# API origin (the code default is a neutral placeholder).
NEXT_PUBLIC_HEALTH_API=https://<your-api-host>

# --- Optional / legacy ------------------------------------------------------

# ANTHROPIC_API_KEY is ONLY used by the optional legacy meal-vision provider
# (functions/_llm/anthropic.ts). The default runtime path is the subscription
# Codex CLI and needs NO API key, so leave this unset unless you deliberately
# wire up the Anthropic provider.
# ANTHROPIC_API_KEY=
