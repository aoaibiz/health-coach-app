# Cloudflare Pages _headers — baseline security headers for the static export.
# Mirrors the headers emitted by the Node server (server/index.mjs SECURITY_HEADERS).
# https://developers.cloudflare.com/pages/configuration/headers/

/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: DENY

# TODO CSP: add a Content-Security-Policy here once the inline theme-init script
# in src/app/layout.tsx is given a build-time hash (or moved to an external file
# with a nonce). A naive `script-src 'self'` would block that inline script and
# break the initial light/dark theme paint, so CSP is intentionally omitted for
# now rather than shipped broken.

# The service worker must not be cached, so push-handler updates take effect.
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate
